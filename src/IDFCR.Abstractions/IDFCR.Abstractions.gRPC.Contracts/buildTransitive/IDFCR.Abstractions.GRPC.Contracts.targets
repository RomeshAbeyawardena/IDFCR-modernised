<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="CopyProtosToProject" BeforeTargets="PrepareForBuild;BeforeBuild">
    <ItemGroup>
      <SourceProtoFiles Include="$(MSBuildThisFileDirectory)..\**\idfcr-shared\v1\*.proto" Condition="Exists('$(MSBuildThisFileDirectory)..\')" />
      <SourceProtoFiles Include="$(MSBuildThisFileDirectory)**\idfcr-shared\v1\*.proto" Condition="'@(SourceProtoFiles)' == ''" />
    </ItemGroup>

    <PropertyGroup>
      <V1Target>$(ProjectDir)Protos\Shared\idfcr-shared\v1\</V1Target>
    </PropertyGroup>

    <Message Text="[Idfcr] Copying @(SourceProtoFiles->Count()) files to $(V1Target)" Importance="high" />

    <MakeDir Directories="$(V1Target)" Condition="!Exists('$(V1Target)')" />

    <Copy
      SourceFiles="@(SourceProtoFiles)"
      DestinationFolder="$(V1Target)"
      SkipUnchangedFiles="true"
      OverwriteReadOnlyFiles="true" />
  </Target>
</Project>