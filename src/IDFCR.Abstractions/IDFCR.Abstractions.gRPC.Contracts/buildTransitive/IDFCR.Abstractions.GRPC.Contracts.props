<Project>

  <!-- Resolve the proto root inside the NuGet package -->
  <PropertyGroup>
    <IDFCR_ProtoSourceRoot>
      $(MSBuildThisFileDirectory)..\contentFiles\any\any\protos
    </IDFCR_ProtoSourceRoot>

    <!-- Destination inside consuming project -->
    <IDFCR_ProtoTargetRoot>
      $(MSBuildProjectDirectory)\Protos\Shared
    </IDFCR_ProtoTargetRoot>
  </PropertyGroup>

  <!-- Gather all proto files from the package -->
  <ItemGroup>
    <IDFCR_ProtoFiles Include="$(IDFCR_ProtoSourceRoot)\**\*.proto" />
  </ItemGroup>

  <!-- Copy them into the consuming project -->
  <Target Name="IDFCR_CopyProtos"
          BeforeTargets="BeforeBuild"
          Condition="Exists('$(IDFCR_ProtoSourceRoot)')">

    <Message Importance="High"
             Text="Copying IDFCR proto files to $(IDFCR_ProtoTargetRoot)" />

    <MakeDir Directories="$(IDFCR_ProtoTargetRoot)" />

    <Copy SourceFiles="@(IDFCR_ProtoFiles)"
          DestinationFiles="@(IDFCR_ProtoFiles->'$(IDFCR_ProtoTargetRoot)\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />

  </Target>
 
</Project>