<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="CopyProtosToProject" BeforeTargets="PrepareForBuild;BeforeBuild">
    <ItemGroup>
      <NuGetSourceFiles Include="$(MSBuildThisFileDirectory)..\contentFiles\any\any\Protos\Shared\idfcr-shared\**\*" />

      <P2PSourceFiles Include="$(MSBuildThisFileDirectory)Proto\Shared\idfcr-shared\**\*" />

      <AllSourceFiles Condition="'@(NuGetSourceFiles)' != ''" Include="@(NuGetSourceFiles)" />
      <AllSourceFiles Condition="'@(NuGetSourceFiles)' == ''" Include="@(P2PSourceFiles)" />
    </ItemGroup>

    <MakeDir Directories="$(ProjectDir)Protos\Shared\idfcr-shared" Condition="!Exists('$(ProjectDir)Protos\Shared\idfcr-shared')" />

    <Copy
      SourceFiles="@(AllSourceFiles)"
      DestinationFolder="$(ProjectDir)Protos\%(RecursiveDir)"
      SkipUnchangedFiles="true"
      OverwriteReadOnlyFiles="true" />

    <Message Text="[Idfcr] Synced protos to $(ProjectDir)Protos\Shared\idfcr-shared" Importance="high" />
  </Target>
</Project>