<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IncludeContentInPack>true</IncludeContentInPack>
    <ContentTargetFolders>contentFiles</ContentTargetFolders>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="10.0.6" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="Protos\Common\**\*.proto"
            PackagePath="contentFiles/any/any/Common/"
            BuildAction="None"
            CopyToOutput="Never" />
  </ItemGroup>
  <ItemGroup>
    <Protobuf Include="$(MSBuildThisFileDirectory)..\contentFiles\any\any\Common\**\*.proto" />
  </ItemGroup>

</Project>