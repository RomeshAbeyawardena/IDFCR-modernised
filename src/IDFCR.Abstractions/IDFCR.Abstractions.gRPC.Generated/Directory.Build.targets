<Project>
  <!--
    When a project under this folder is built, and the gRPC.Contracts project
    is part of the solution (ProjectReference chain), copy the proto files
    to the consuming project's Protos\Shared folder.
  -->
  <PropertyGroup>
    <_ContractsProtoRoot>$(MSBuildThisFileDirectory)..\IDFCR.Abstractions.gRPC.Contracts\Protos\</_ContractsProtoRoot>
    <IDFCR_ProtoTargetRoot>$(MSBuildProjectDirectory)\Protos\Shared\</IDFCR_ProtoTargetRoot>
  </PropertyGroup>

  <Target Name="IDFCR_CopyProtos"
          AfterTargets="Build"
          Condition="'$(DesignTimeBuild)' != 'true' and Exists('$(_ContractsProtoRoot)')">
    <ItemGroup>
      <IDFCR_ProtoFiles Include="$(_ContractsProtoRoot)**\*.proto" />
    </ItemGroup>

    <Message Importance="High" Text="[IDFCR] Copying proto files to $(IDFCR_ProtoTargetRoot)" />
    <MakeDir Directories="$(IDFCR_ProtoTargetRoot)" />
    <Copy SourceFiles="@(IDFCR_ProtoFiles)"
          DestinationFiles="@(IDFCR_ProtoFiles->'$(IDFCR_ProtoTargetRoot)%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>
</Project>