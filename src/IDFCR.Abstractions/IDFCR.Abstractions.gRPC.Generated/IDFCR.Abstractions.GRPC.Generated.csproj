<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Google.Protobuf" />
    <PackageReference Include="Grpc.Core.Api" />
    <PackageReference Include="Grpc.Tools" PrivateAssets="All" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\IDFCR.Abstractions.gRPC.Contracts\IDFCR.Abstractions.GRPC.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Protobuf Include="Protos\**\*.proto" GrpcServices="Both" />
  </ItemGroup>
  
  <Import Project="..\IDFCR.Abstractions.gRPC.Contracts\buildTransitive\IDFCR.Abstractions.GRPC.Contracts.targets" Condition="Exists('..\IDFCR.Abstractions.gRPC.Contracts\buildTransitive\IDFCR.Abstractions.GRPC.Contracts.targets')" />
</Project>